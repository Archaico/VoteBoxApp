# VoteBox — Environment Variables
#
# Copy this file to .env and fill in real values.
# EXPO_PUBLIC_* variables are safe to bundle in the client app — they will
# be visible in your compiled APK. On mainnet, move signing server-side.

# Foundation wallet ed25519 signing key (32 bytes, hex-encoded).
# Generate with cardano-cli, fund from preprod faucet, then paste the hex here.
# See BlockchainService.ts header for the exact cardano-cli commands.
# Leave blank during development — transactions will be simulated.
EXPO_PUBLIC_FOUNDATION_PRIVATE_KEY=

# Blockfrost project ID for Cardano preprod testnet.
# Create a free account at https://blockfrost.io and generate a preprod project.
EXPO_PUBLIC_BLOCKFROST_PROJECT_ID=
